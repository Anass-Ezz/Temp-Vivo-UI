{
  "source": {
    "include": [
      "src"
    ],
    "includePattern": "\\.js$",
    "excludePattern": "(node_modules|src[\\\\/]service|src[\\\\/]views[\\\\/]uikit)"
  },
  "opts": {
    "recurse": true,
    "destination": "docs/",
    "readme": "README.md"
  },
  "plugins": [
    "plugins/markdown"
  ],
  "templates": {
    "cleverLinks": true
  }
}